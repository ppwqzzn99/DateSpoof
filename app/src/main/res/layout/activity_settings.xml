<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 忙聫聬莽陇潞 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="猫庐戮莽陆庐莽聸庐忙聽聡忙聴楼忙聹聼氓聬聨茂录聦茅聹聙氓聹篓 LSPosed 莽庐隆莽聬聠氓聶篓盲赂颅茅聡聧忙聳掳氓聥戮茅聙聣忙篓隆氓聺聴氓鹿露茅聡聧氓聬炉莽聸庐忙聽聡氓潞聰莽聰篓茫聙聜"
            android:textSize="13sp"
            android:textColor="#666666"
            android:paddingBottom="16dp" />

        <!-- 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 氓录聙氓聟鲁 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="氓聬炉莽聰篓盲录陋猫拢聟"
                android:textSize="16sp"
                android:textColor="#000000" />

            <Switch
                android:id="@+id/sw_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="12dp" />

        <!-- 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 忙聴楼忙聹聼猫戮聯氓聟楼 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="莽聸庐忙聽聡忙聴楼忙聹聼"
            android:textSize="14sp"
            android:textColor="#888888"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/et_year"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:hint="氓鹿麓"
                android:inputType="number"
                android:gravity="center"
                android:textSize="16sp"
                android:background="@android:drawable/edit_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 氓鹿麓  "
                android:textSize="16sp"
                android:textColor="#000000" />

            <EditText
                android:id="@+id/et_month"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="忙聹聢"
                android:inputType="number"
                android:gravity="center"
                android:textSize="16sp"
                android:background="@android:drawable/edit_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 忙聹聢  "
                android:textSize="16sp"
                android:textColor="#000000" />

            <EditText
                android:id="@+id/et_day"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="忙聴楼"
                android:inputType="number"
                android:gravity="center"
                android:textSize="16sp"
                android:background="@android:drawable/edit_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 忙聴楼"
                android:textSize="16sp"
                android:textColor="#000000" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp" />

        <!-- 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 忙聦聣茅聮庐氓聦潞 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="盲驴聺氓颅聵猫庐戮莽陆庐"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_verify"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="茅陋聦猫炉聛茂录職猫炉禄氓聫聳氓路虏盲驴聺氓颅聵莽職聞茅聟聧莽陆庐"
            android:textSize="14sp"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 茅陋聦猫炉聛莽禄聯忙聻聹 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="茅陋聦猫炉聛莽禄聯忙聻聹茂录職"
            android:textSize="14sp"
            android:textColor="#888888"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:textSize="13sp"
            android:textColor="#333333"
            android:fontFamily="monospace"
            android:text="氓掳職忙聹陋茅陋聦猫炉聛" />

    </LinearLayout>
</ScrollView>
